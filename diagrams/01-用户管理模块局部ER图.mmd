        varchar 用户身份
        varchar 账号状态
        datetime 注册时间
    }

    管理员 {
        int 管理员ID PK
        varchar 姓名
    }

    商家 {
        int 商家ID PK
        varchar 商家名称
        varchar 联系电话
        varchar 营业地址_省
        varchar 营业地址_市
        varchar 营业地址_区
        varchar 营业地址_详细
