    }

    顾客 {
        int 顾客ID PK
        varchar 姓名
        varchar 配送地址_省
        varchar 配送地址_市
        varchar 配送地址_区
        varchar 配送地址_详细
    }

    骑手 {
        int 骑手ID PK
        varchar 姓名
        varchar 配送状态
        int 累计配送单数
    }

